// ============================================================================
// SUNSET ERP - PRISMA SCHEMA
// ============================================================================
// Multi-tenant SaaS ERP Platform
// Database: PostgreSQL 15+
// ORM: Prisma 5+
// 
// Table Naming Convention:
// - saas_*   : SaaS core (tenants, subscriptions)
// - auth_*   : Authentication & authorization
// - mc_*     : Multi-currency
// - i18n_*   : Internationalization
// - po_*     : Procurement (purchase orders)
// - in_*     : Inventory
// - mfg_*    : Manufacturing
// - so_*     : Sales orders
// - ac_*     : Accounting
// - fn_*     : Finance
// - dist_*   : Distribution
// - maint_*  : Maintenance
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

// Auto-generate ERD as SVG
generator erd {
  provider = "prisma-erd-generator"
  output   = "../../docs/02-architecture/diagrams/erd.svg"
  theme    = "forest"
}

// Auto-generate ERD as Mermaid (renders in GitHub)
generator erd_mermaid {
  provider = "prisma-erd-generator"
  output   = "../../docs/02-architecture/diagrams/erd.md"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// SAAS CORE TABLES (saas_*)
// ============================================================================

model Tenant {
  id        String  @id @default(uuid()) @db.Uuid
  code      String  @unique @db.VarChar(50)
  name      String  @db.VarChar(255)
  legalName String? @map("legal_name") @db.VarChar(255)
  taxId     String? @map("tax_id") @db.VarChar(50)
  subdomain String? @unique @db.VarChar(100)

  // Location
  country     String  @db.VarChar(2) // ISO 3166-1 alpha-2
  industry    String? @db.VarChar(100)
  companySize String? @map("company_size") @db.VarChar(50)

  // Branding
  logoUrl        String? @map("logo_url") @db.VarChar(500)
  primaryColor   String? @map("primary_color") @db.VarChar(7)
  secondaryColor String? @map("secondary_color") @db.VarChar(7)

  // Subscription
  subscriptionPlan     String    @default("free") @map("subscription_plan") @db.VarChar(50)
  subscriptionStatus   String    @default("trial") @map("subscription_status") @db.VarChar(20)
  trialStartsAt        DateTime? @map("trial_starts_at")
  trialEndsAt          DateTime? @map("trial_ends_at")
  subscriptionStartsAt DateTime? @map("subscription_starts_at")
  subscriptionEndsAt   DateTime? @map("subscription_ends_at")

  // Settings
  defaultCurrency String @default("USD") @map("default_currency") @db.VarChar(3)
  defaultLanguage String @default("en-US") @map("default_language") @db.VarChar(10)
  fiscalYearStart Int    @default(1) @map("fiscal_year_start") // Month 1-12
  timezone        String @default("UTC") @db.VarChar(50)

  // Status
  status String @default("active") @db.VarChar(20)

  // Metadata
  settings Json?

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  userTenants         UserTenant[]
  subscriptions       Subscription[]
  invoices            Invoice[]
  usageRecords        UsageRecord[]
  roles               Role[]
  suppliers           Supplier[]
  items               Item[]
  warehouses          Warehouse[]
  stock               Stock[]
  stockMovements      StockMovement[]
  boms                Bom[]
  workCenters         WorkCenter[]
  productionOrders    ProductionOrder[]
  customers           Customer[]
  salesOrders         SalesOrder[]
  accounts            Account[]
  journalEntries      JournalEntry[]
  PurchaseOrder       PurchaseOrder[]
  PurchaseOrderLine   PurchaseOrderLine[]
  BomComponent        BomComponent[]
  SalesOrderLine      SalesOrderLine[]
  JournalEntryLine    JournalEntryLine[]
  fiscalPeriods       FiscalPeriod[]
  budgets             Budget[] // <-- ADD THIS
  budgetLines         BudgetLine[] // <-- ADD THIS
  cashFlowProjections CashFlowProjection[] // <-- ADD THIS
  cashFlowLines       CashFlowLine[] // <-- ADD THIS
  arInvoices     ArInvoice[]
  arInvoiceLines ArInvoiceLine[]
  arPayments     ArPayment[]
  moLaborActuals    MoLaborActual[]
  moMaterialActuals MoMaterialActual[]
  productionVariances ProductionVariance[]
  @@map("saas_tenants")
}

model SubscriptionPlan {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String? @db.Text

  // Pricing
  priceMonthly Decimal @map("price_monthly") @db.Decimal(10, 2)
  priceYearly  Decimal @map("price_yearly") @db.Decimal(10, 2)

  // Limits (JSONB)
  limits   Json // { users: 5, items: 1000, storage_gb: 10, transactions_per_month: 500 }
  features Json?

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("saas_subscription_plans")
}

model Subscription {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  planId   String @map("plan_id") @db.Uuid

  status       String @default("active") @db.VarChar(20)
  billingCycle String @default("monthly") @map("billing_cycle") @db.VarChar(20)

  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")

  trialStart DateTime? @map("trial_start")
  trialEnd   DateTime? @map("trial_end")

  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@map("saas_subscriptions")
}

model Invoice {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  subscriptionId String? @map("subscription_id") @db.Uuid

  invoiceNumber String @unique @map("invoice_number") @db.VarChar(50)
  status        String @default("draft") @db.VarChar(20)

  // Amounts
  subtotal Decimal @db.Decimal(12, 2)
  tax      Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  currency String @default("USD") @db.VarChar(3)

  // Dates
  invoiceDate DateTime  @default(dbgenerated("CURRENT_DATE")) @map("invoice_date") @db.Date
  dueDate     DateTime  @map("due_date") @db.Date
  paidAt      DateTime? @map("paid_at")

  // Payment
  paymentMethod   String? @map("payment_method") @db.VarChar(50)
  stripeInvoiceId String? @map("stripe_invoice_id") @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("saas_invoices")
}

model UsageRecord {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  metricName String   @map("metric_name") @db.VarChar(100)
  quantity   Decimal  @db.Decimal(12, 2)
  recordedAt DateTime @default(now()) @map("recorded_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, metricName])
  @@map("saas_usage_records")
}

// ============================================================================
// AUTHENTICATION TABLES (auth_*)
// ============================================================================

model User {
  id           String @id @default(uuid()) @db.Uuid
  email        String @unique @db.VarChar(255)
  passwordHash String @map("password_hash") @db.VarChar(255)

  firstName String  @map("first_name") @db.VarChar(100)
  lastName  String  @map("last_name") @db.VarChar(100)
  phone     String? @db.VarChar(20)
  avatarUrl String? @map("avatar_url") @db.VarChar(500)

  // Preferences
  locale   String @default("en-US") @db.VarChar(10)
  timezone String @default("UTC") @db.VarChar(50)

  // Status
  status            String    @default("active") @db.VarChar(20)
  emailVerifiedAt   DateTime? @map("email_verified_at")
  lastLoginAt       DateTime? @map("last_login_at")
  passwordChangedAt DateTime? @map("password_changed_at")

  // 2FA
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  twoFactorSecret  String? @map("two_factor_secret") @db.VarChar(255)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  userTenants UserTenant[]
  userRoles   UserRole[]

  // Audit fields (created_by, updated_by references)
  suppliersCreated      Supplier[]      @relation("SupplierCreatedBy")
  suppliersUpdated      Supplier[]      @relation("SupplierUpdatedBy")
  itemsCreated          Item[]          @relation("ItemCreatedBy")
  itemsUpdated          Item[]          @relation("ItemUpdatedBy")
  purchaseOrdersCreated PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  purchaseOrdersUpdated PurchaseOrder[] @relation("PurchaseOrderUpdatedBy")
  salesOrdersCreated    SalesOrder[]    @relation("SalesOrderCreatedBy")
  salesOrdersUpdated    SalesOrder[]    @relation("SalesOrderUpdatedBy")

  @@map("auth_users")
}

model UserTenant {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")

  joinedAt  DateTime @default(now()) @map("joined_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("auth_user_tenants")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  code        String  @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String? @db.Text
  isSystem    Boolean @default(false) @map("is_system")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("auth_roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique @db.VarChar(100)
  name        String  @db.VarChar(100)
  description String? @db.Text
  module      String  @db.VarChar(50)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@map("auth_permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("auth_role_permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([tenantId])
  @@map("auth_user_roles")
}

// ============================================================================
// MULTI-CURRENCY TABLES (mc_*)
// ============================================================================

model Currency {
  id            String  @id @default(uuid()) @db.Uuid
  code          String  @unique @db.VarChar(3) // ISO 4217
  name          String  @db.VarChar(100)
  symbol        String  @db.VarChar(10)
  decimalPlaces Int     @default(2) @map("decimal_places") @db.SmallInt
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  exchangeRatesFrom ExchangeRate[] @relation("FromCurrency")
  exchangeRatesTo   ExchangeRate[] @relation("ToCurrency")

  @@index([code])
  @@map("mc_currencies")
}

model ExchangeRate {
  id            String   @id @default(uuid()) @db.Uuid
  fromCurrency  String   @map("from_currency") @db.VarChar(3)
  toCurrency    String   @map("to_currency") @db.VarChar(3)
  rate          Decimal  @db.Decimal(18, 6)
  effectiveDate DateTime @map("effective_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fromCurrencyRelation Currency @relation("FromCurrency", fields: [fromCurrency], references: [code])
  toCurrencyRelation   Currency @relation("ToCurrency", fields: [toCurrency], references: [code])

  @@unique([fromCurrency, toCurrency, effectiveDate])
  @@index([fromCurrency])
  @@index([toCurrency])
  @@index([effectiveDate])
  @@map("mc_exchange_rates")
}

// ============================================================================
// INTERNATIONALIZATION TABLES (i18n_*)
// ============================================================================

model Language {
  id         String  @id @default(uuid()) @db.Uuid
  code       String  @unique @db.VarChar(10) // en-US, es-DO
  name       String  @db.VarChar(100)
  nativeName String  @map("native_name") @db.VarChar(100)
  isRtl      Boolean @default(false) @map("is_rtl")
  isActive   Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  translations Translation[]

  @@index([code])
  @@map("i18n_languages")
}

model Translation {
  id               String  @id @default(uuid()) @db.Uuid
  languageCode     String  @map("language_code") @db.VarChar(10)
  translationKey   String  @map("translation_key") @db.VarChar(255)
  translationValue String  @map("translation_value") @db.Text
  context          String? @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  language Language @relation(fields: [languageCode], references: [code])

  @@unique([languageCode, translationKey])
  @@index([languageCode])
  @@index([translationKey])
  @@map("i18n_translations")
}

// ============================================================================
// PROCUREMENT TABLES (po_*)
// ============================================================================

model Supplier {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  code      String  @db.VarChar(50)
  name      String  @db.VarChar(255)
  legalName String? @map("legal_name") @db.VarChar(255)
  taxId     String? @map("tax_id") @db.VarChar(50)

  // Contact
  phone   String? @db.VarChar(20)
  email   String? @db.VarChar(255)
  website String? @db.VarChar(255)

  // Payment
  paymentTerms String?  @map("payment_terms") @db.VarChar(50)
  currency     String?  @db.VarChar(3)
  creditLimit  Decimal? @map("credit_limit") @db.Decimal(15, 2)

  category String? @db.VarChar(100)
  isActive Boolean @default(true) @map("is_active")
  notes    String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  createdByUser  User            @relation("SupplierCreatedBy", fields: [createdBy], references: [id])
  updatedByUser  User            @relation("SupplierUpdatedBy", fields: [updatedBy], references: [id])
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, code])
  @@index([tenantId, name])
  @@map("po_suppliers")
}

model PurchaseOrder {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  poNumber        String    @map("po_number") @db.VarChar(50)
  supplierId      String    @map("supplier_id") @db.Uuid
  poDate          DateTime  @default(dbgenerated("CURRENT_DATE")) @map("po_date") @db.Date
  expectedDate    DateTime? @map("expected_date") @db.Date
  deliveryAddress String?   @map("delivery_address") @db.Text

  // Payment
  paymentTerms String? @map("payment_terms") @db.VarChar(50)
  currency     String? @db.VarChar(3)
  exchangeRate Decimal @default(1) @map("exchange_rate") @db.Decimal(18, 6)

  // Amounts
  subtotal       Decimal @default(0) @map("subtotal") @db.Decimal(15, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(15, 2)
  taxAmount      Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  total          Decimal @default(0) @db.Decimal(15, 2)

  status String  @default("draft") @db.VarChar(20)
  notes  String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  createdByUser User                @relation("PurchaseOrderCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User                @relation("PurchaseOrderUpdatedBy", fields: [updatedBy], references: [id])
  lines         PurchaseOrderLine[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([tenantId, poNumber])
  @@index([tenantId, supplierId])
  @@index([tenantId, status])
  @@index([poDate])
  @@map("po_purchase_orders")
}

model PurchaseOrderLine {
  id              String  @id @default(uuid()) @db.Uuid
  tenantId        String  @map("tenant_id") @db.Uuid
  purchaseOrderId String  @map("purchase_order_id") @db.Uuid
  lineNumber      Int     @map("line_number")
  itemId          String  @map("item_id") @db.Uuid
  description     String? @db.Text

  // Quantities
  orderedQuantity  Decimal @map("ordered_quantity") @db.Decimal(15, 3)
  receivedQuantity Decimal @default(0) @map("received_quantity") @db.Decimal(15, 3)
  uom              String  @db.VarChar(20)

  // Pricing
  unitPrice       Decimal   @map("unit_price") @db.Decimal(15, 4)
  discountPercent Decimal   @default(0) @map("discount_percent") @db.Decimal(5, 2)
  taxCode         String?   @map("tax_code") @db.VarChar(20)
  lineTotal       Decimal   @map("line_total") @db.Decimal(15, 2)
  expectedDate    DateTime? @map("expected_date") @db.Date

  status String @default("open") @db.VarChar(20)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id])

  @@index([tenantId])
  @@index([purchaseOrderId])
  @@index([itemId])
  @@map("po_purchase_order_lines")
}

// ============================================================================
// INVENTORY TABLES (in_*)
// ============================================================================

model Item {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  code        String  @db.VarChar(50)
  name        String  @db.VarChar(255)
  description String? @db.Text

  // Type
  itemType   String  @map("item_type") @db.VarChar(50)
  categoryId String? @map("category_id") @db.Uuid
  baseUom    String  @map("base_uom") @db.VarChar(20)

  // Flags
  isStockable      Boolean @default(true) @map("is_stockable")
  isPurchasable    Boolean @default(true) @map("is_purchasable")
  isSaleable       Boolean @default(true) @map("is_saleable")
  isManufacturable Boolean @default(false) @map("is_manufacturable")

  // Tracking
  isLotTracked    Boolean @default(false) @map("is_lot_tracked")
  isSerialTracked Boolean @default(false) @map("is_serial_tracked")
  isExpiryTracked Boolean @default(false) @map("is_expiry_tracked")

  // Valuation
  valuationMethod String   @default("average") @map("valuation_method") @db.VarChar(50)
  standardCost    Decimal? @map("standard_cost") @db.Decimal(15, 4)

  // Planning
  leadTimeDays      Int     @default(0) @map("lead_time_days")
  safetyStock       Decimal @default(0) @map("safety_stock") @db.Decimal(15, 3)
  reorderPoint      Decimal @default(0) @map("reorder_point") @db.Decimal(15, 3)
  reorderQuantity   Decimal @default(0) @map("reorder_quantity") @db.Decimal(15, 3)
  defaultSupplierId String? @map("default_supplier_id") @db.Uuid

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  createdByUser      User                @relation("ItemCreatedBy", fields: [createdBy], references: [id])
  updatedByUser      User                @relation("ItemUpdatedBy", fields: [updatedBy], references: [id])
  stock              Stock[]
  stockMovements     StockMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  salesOrderLines    SalesOrderLine[]
  boms               Bom[]               @relation("BomParentItem")
  bomComponents      BomComponent[]
  arInvoiceLines ArInvoiceLine[]
  moMaterialActuals MoMaterialActual[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, code])
  @@index([tenantId, name])
  @@index([tenantId, itemType])
  @@map("in_items")
}

model Warehouse {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  code          String  @db.VarChar(50)
  name          String  @db.VarChar(255)
  warehouseType String  @default("regular") @map("warehouse_type") @db.VarChar(50)
  address       String? @db.Text
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid

