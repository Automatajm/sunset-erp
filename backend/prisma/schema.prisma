model StockCountSession {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id")   @db.Uuid
  sessionNumber String   @map("session_number") @db.VarChar(50)  // CC-YYYY-NNNN
  warehouseId   String   @map("warehouse_id") @db.Uuid
  description   String?  @db.Text
  countDate     DateTime @default(dbgenerated("CURRENT_DATE")) @map("count_date") @db.Date
  status        String   @default("draft") @db.VarChar(20)
  // draft | in_progress | pending_approval | approved | posted | cancelled

  // Variance summary — populated on submitForApproval
  totalLinesCount    Int?     @map("total_lines_count")
  linesWithVariance  Int?     @map("lines_with_variance")
  totalVarianceValue Decimal? @map("total_variance_value") @db.Decimal(15, 2)

  // Approval — requires INVENTORY:APPROVE
  approvedBy    String?   @map("approved_by") @db.Uuid
  approvedAt    DateTime? @map("approved_at")
  approvalNotes String?   @map("approval_notes") @db.Text

  // Posted
  postedAt DateTime? @map("posted_at")

  notes     String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant    Tenant    @relation(fields: [tenantId],    references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  lines     StockCountLine[]
  assignments StockCountAssignment[]

  @@unique([tenantId, sessionNumber])
  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, status])
  @@index([countDate])
  @@map("in_stock_count_sessions")
}

model StockCountLine {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @map("tenant_id")  @db.Uuid
  sessionId String @map("session_id") @db.Uuid
  itemId    String @map("item_id")    @db.Uuid

  // System snapshot — taken when session is created
  systemStorageQty  Decimal @map("system_storage_qty")  @db.Decimal(15, 3)
  storageUom        String  @map("storage_uom")         @db.VarChar(20)
  systemPurchaseQty Decimal @map("system_purchase_qty") @db.Decimal(15, 3)
  purchaseUom       String  @map("purchase_uom")        @db.VarChar(20)
  unitCostSnapshot  Decimal @map("unit_cost_snapshot")  @db.Decimal(15, 4)
  // WAC at snapshot time — used for variance value (ADR-019)

  // Counted quantities — entered by user in storageUom
  // system auto-converts to purchaseUom via UomService
  countedStorageQty  Decimal? @map("counted_storage_qty")  @db.Decimal(15, 3)
  countedPurchaseQty Decimal? @map("counted_purchase_qty") @db.Decimal(15, 3)

  // Variances = counted - system
  varianceStorageQty  Decimal? @map("variance_storage_qty")  @db.Decimal(15, 3)
  variancePurchaseQty Decimal? @map("variance_purchase_qty") @db.Decimal(15, 3)
  varianceValue       Decimal? @map("variance_value")        @db.Decimal(15, 2)
  // varianceValue = variancePurchaseQty × unitCostSnapshot (ADR-019)

  // Line status
  status String @default("pending") @db.VarChar(20)
  // pending | counted | confirmed | adjusted

  lotNumber    String? @map("lot_number")    @db.VarChar(100)
  serialNumber String? @map("serial_number") @db.VarChar(100)
  levelId      String? @map("level_id")      @db.Uuid
  binId        String? @map("bin_id")         @db.Uuid
  locationCode String? @map("location_code") @db.VarChar(100)
  assignedToUserId String? @map("assigned_to_user_id") @db.Uuid
  level WarehouseLevel? @relation(fields: [levelId], references: [id])
  bin   WarehouseBin?   @relation(fields: [binId],   references: [id])
  notes        String? @db.Text

  // FK to adjustment movement (set when session is posted)
  adjustmentMovementId String? @map("adjustment_movement_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid

  tenant  Tenant            @relation(fields: [tenantId],  references: [id])
  session StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item    Item              @relation(fields: [itemId],     references: [id])

  @@unique([sessionId, itemId, lotNumber, serialNumber])
  @@index([tenantId])
  @@index([sessionId])
  @@index([itemId])
  @@index([status])
  @@map("in_stock_count_lines")
}

// ── Sprint 14F: Count line assignments ────────────────────────────────────────
// Supervisor assigns lines to specific users by any combination of:
// zone / aisle / level / bin / category / macroCategory / specific items

model StockCountAssignment {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @map("tenant_id")  @db.Uuid
  sessionId String @map("session_id") @db.Uuid
  userId    String @map("user_id")    @db.Uuid
  // user assigned to count these lines

  // Filter criteria — any combination, all optional
  // If empty → all unassigned lines
  zoneIds          String[] @map("zone_ids")           @db.Uuid
  aisleIds         String[] @map("aisle_ids")          @db.Uuid
  levelIds         String[] @map("level_ids")          @db.Uuid
  binIds           String[] @map("bin_ids")            @db.Uuid
  categoryIds      String[] @map("category_ids")       @db.Uuid
  macroCategoryIds String[] @map("macro_category_ids") @db.Uuid
  itemIds          String[] @map("item_ids")           @db.Uuid
  // explicit item overrides

  // Resolved line IDs (populated when assignment is created)
  assignedLineIds  String[] @map("assigned_line_ids")  @db.Uuid

  notes     String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  createdBy String    @map("created_by") @db.Uuid

  tenant  Tenant            @relation(fields: [tenantId],  references: [id])
  session StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sessionId])
  @@index([userId])
  @@map("in_stock_count_assignments")
}

// ── Sprint 14F: Stock location update log ─────────────────────────────────────
// Tracks every time an item's bin/level is updated
// Methods: scan (mobile double-scan), bulk (CSV upload), manual (desktop)

model StockLocationUpdate {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id")   @db.Uuid
  itemId      String  @map("item_id")     @db.Uuid
  warehouseId String  @map("warehouse_id") @db.Uuid
  stockId     String? @map("stock_id")    @db.Uuid
  // FK to in_stock record (null if not yet resolved)

  // Previous location (null if first assignment)
  fromLevelId String? @map("from_level_id") @db.Uuid
  fromBinId   String? @map("from_bin_id")   @db.Uuid
  fromCode    String? @map("from_code")     @db.VarChar(100)

  // New location
  toLevelId   String? @map("to_level_id")   @db.Uuid
  toBinId     String? @map("to_bin_id")     @db.Uuid
  toCode      String  @map("to_code")       @db.VarChar(100)

  method    String  @db.VarChar(20)
  // scan | bulk | manual
  batchRef  String? @map("batch_ref") @db.VarChar(100)
  // reference to bulk upload batch ID if method = bulk
  notes     String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id])
  item   Item   @relation(fields: [itemId],   references: [id])

  @@index([tenantId])
  @@index([tenantId, itemId])
  @@index([tenantId, warehouseId])
  @@index([createdAt])
  @@map("in_stock_location_updates")
}

// ── Sprint 14F: Bulk location import batch ────────────────────────────────────
// Tracks a bulk upload: itemCode + binCode + qty
// Validates that quantities split across bins match system total
// Alert if sum(qty per item) ≠ system stock (split mismatch)

model StockLocationBatch {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @map("tenant_id")  @db.Uuid
  batchRef  String @map("batch_ref")  @db.VarChar(100)
  // auto-generated: BLK-YYYY-NNNN

  warehouseId String  @map("warehouse_id") @db.Uuid
  status      String  @default("draft") @db.VarChar(20)
  // draft | validating | validated | posted | failed

  // Validation summary (populated after validate step)
  totalLines       Int?     @map("total_lines")
  linesOk          Int?     @map("lines_ok")
  linesWithMismatch Int?    @map("lines_with_mismatch")
  // items where sum(uploadedQty) ≠ systemStock
  linesWithExcess  Int?     @map("lines_with_excess")
  // items where sum(uploadedQty) > systemStock
  linesWithShortage Int?   @map("lines_with_shortage")
  // items where sum(uploadedQty) < systemStock

  rawData   Json?   @map("raw_data")
  // original upload rows stored for audit

  notes     String?   @db.Text
  postedAt  DateTime? @map("posted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id])
  lines  StockLocationBatchLine[]

  @@unique([tenantId, batchRef])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("in_stock_location_batches")
}

model StockLocationBatchLine {
  id      String @id @default(uuid()) @db.Uuid
  batchId String @map("batch_id") @db.Uuid
  lineNo  Int    @map("line_no")

  // Input data from upload
  itemCode    String  @map("item_code")    @db.VarChar(50)
  binCode     String  @map("bin_code")     @db.VarChar(100)
  qty         Decimal @db.Decimal(15, 3)
  uom         String  @db.VarChar(20)

  // Resolved FKs (populated during validation)
  itemId  String? @map("item_id")  @db.Uuid
  binId   String? @map("bin_id")   @db.Uuid
  levelId String? @map("level_id") @db.Uuid

  // Validation result
  validationStatus  String  @default("pending") @map("validation_status") @db.VarChar(20)
  // pending | ok | item_not_found | bin_not_found | qty_mismatch | qty_excess | qty_shortage
  validationMessage String? @map("validation_message") @db.Text
  systemQty         Decimal? @map("system_qty") @db.Decimal(15, 3)
  // system stock at time of validation (for mismatch comparison)

  createdAt DateTime @default(now()) @map("created_at")

  batch StockLocationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([validationStatus])
  @@map("in_stock_location_batch_lines")
}

// ============================================================================
// SPRINT 15 — FULL PROCUREMENT CYCLE (po_*)
// GeneralNeed → PR → RFQ → PO
// ============================================================================

model GeneralNeed {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  gnNumber    String   @map("gn_number") @db.VarChar(50)  // GN-YYYY-NNNN
  title       String   @db.VarChar(255)
  description String?  @db.Text
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end")   @db.Date
  source      String   @default("manual") @db.VarChar(20)
  // manual | mrp_explode
  status      String   @default("draft") @db.VarChar(20)
  // draft | in_progress | completed | cancelled
  notes       String?  @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String    @map("updated_by") @db.Uuid
  deletedBy   String?   @map("deleted_by") @db.Uuid
  tenant Tenant            @relation(fields: [tenantId], references: [id])
  lines  GeneralNeedLine[]
  rfqs   Rfq[]
  @@unique([tenantId, gnNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([periodStart])
  @@map("po_general_needs")
}

model GeneralNeedLine {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  gnId          String   @map("gn_id") @db.Uuid
  lineNumber    Int      @map("line_number")
  itemId        String?  @map("item_id") @db.Uuid
  // null = generic item not yet in catalog
  genericDescription String? @map("generic_description") @db.Text
  quantity      Decimal  @db.Decimal(15, 3)
  uom           String   @db.VarChar(20)
  requiredDate  DateTime @map("required_date") @db.Date
  // Suggested supplier (from SupplierItem.isPreferred)
  suggestedSupplierId String? @map("suggested_supplier_id") @db.Uuid
  estimatedUnitCost   Decimal? @map("estimated_unit_cost") @db.Decimal(15, 4)
  // Source — if exploded from MO
  sourceType    String?  @map("source_type") @db.VarChar(20)
  // mo | manual
  sourceMoId    String?  @map("source_mo_id") @db.Uuid
  // FK to ProductionOrder
  // Conversion tracking
  prLineId           String?  @map("pr_line_id") @db.Uuid
  // set when converted to PR
  // MRP signal — ConsumptionGroup (normalized production UOM)
  consumptionGroupId String?  @map("consumption_group_id") @db.Uuid
  status             String   @default("pending") @db.VarChar(20)
  // pending | converted | cancelled
  notes         String?  @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt      @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdBy     String    @map("created_by") @db.Uuid
  updatedBy     String    @map("updated_by") @db.Uuid
  tenant            Tenant               @relation(fields: [tenantId],           references: [id])
  generalNeed       GeneralNeed          @relation(fields: [gnId],               references: [id], onDelete: Cascade)
  item              Item?                @relation(fields: [itemId],             references: [id])
  suggestedSupplier Supplier?            @relation("GnLineSuggestedSupplier",    fields: [suggestedSupplierId], references: [id])
  purchaseRequisitionLine PurchaseRequisitionLine? @relation(fields: [prLineId],           references: [id])
  consumptionGroup        ConsumptionGroup?         @relation(fields: [consumptionGroupId], references: [id])
  rfqLines                RfqLine[]                 @relation("RfqLineFromGn")
  @@index([tenantId])
  @@index([gnId])
  @@index([itemId])
  @@index([status])
  @@map("po_general_need_lines")
}

model Rfq {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  rfqNumber        String    @map("rfq_number") @db.VarChar(50)  // RFQ-YYYY-NNNN
  title            String    @db.VarChar(255)
  status           String    @default("draft") @db.VarChar(20)
  // draft | sent | partial_response | fully_responded | awarded | cancelled
  issueDate        DateTime  @default(dbgenerated("CURRENT_DATE")) @map("issue_date") @db.Date
  responseDeadline DateTime? @map("response_deadline") @db.Date
  currency         String    @default("USD") @db.VarChar(3)
  // Source PR (optional — puede ser manual sin PR)
  prId             String?   @map("pr_id") @db.Uuid
  // Source GN (optional)
  gnId             String?   @map("gn_id") @db.Uuid
  notes            String?   @db.Text
  awardedAt        DateTime? @map("awarded_at")
  awardedBy        String?   @map("awarded_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  createdBy        String    @map("created_by") @db.Uuid
  updatedBy        String    @map("updated_by") @db.Uuid
  deletedBy        String?   @map("deleted_by") @db.Uuid
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  purchaseRequisition PurchaseRequisition? @relation(fields: [prId], references: [id])
  generalNeed         GeneralNeed?         @relation(fields: [gnId], references: [id])
  lines               RfqLine[]
  rfqSuppliers        RfqSupplier[]
  purchaseOrders      PurchaseOrder[]
  @@unique([tenantId, rfqNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([issueDate])
  @@index([tenantId, gnId])
  @@map("po_rfqs")
}

model RfqLine {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  rfqId        String   @map("rfq_id") @db.Uuid
  lineNumber   Int      @map("line_number")
  itemId       String?  @map("item_id") @db.Uuid
  genericDescription String? @map("generic_description") @db.Text
  quantity     Decimal  @db.Decimal(15, 3)
  uom          String   @db.VarChar(20)
  requiredDate DateTime @map("required_date") @db.Date
  // Source traceability
  prLineId     String?  @map("pr_line_id") @db.Uuid
  gnLineId     String?  @map("gn_line_id") @db.Uuid
  // Award result — set when line is awarded
  awardedSupplierId    String?  @map("awarded_supplier_id") @db.Uuid
  awardedResponseLineId String? @map("awarded_response_line_id") @db.Uuid
  awardedUnitPrice     Decimal? @map("awarded_unit_price") @db.Decimal(15, 4)
  awardedQty           Decimal? @map("awarded_qty") @db.Decimal(15, 3)
  // Conversion
  poLineId     String?  @map("po_line_id") @db.Uuid
  status       String   @default("open") @db.VarChar(20)
  // open | partially_awarded | awarded | cancelled
  notes        String?  @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdBy    String    @map("created_by") @db.Uuid
  updatedBy    String    @map("updated_by") @db.Uuid
  tenant            Tenant                @relation(fields: [tenantId], references: [id])
  rfq               Rfq                   @relation(fields: [rfqId],    references: [id], onDelete: Cascade)
  item              Item?                 @relation(fields: [itemId],   references: [id])
  prLine            PurchaseRequisitionLine? @relation("RfqLineFromPr", fields: [prLineId], references: [id])
  gnLine            GeneralNeedLine?      @relation("RfqLineFromGn",    fields: [gnLineId], references: [id])
  awardedSupplier   Supplier?             @relation("RfqLineAwardedSupplier", fields: [awardedSupplierId], references: [id])
  purchaseOrderLine PurchaseOrderLine?    @relation("RfqLineToPo",      fields: [poLineId], references: [id])
  responseLines     RfqResponseLine[]
  @@index([tenantId])
  @@index([rfqId])
  @@index([itemId])
  @@index([status])
  @@map("po_rfq_lines")
}

model RfqSupplier {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  rfqId       String    @map("rfq_id") @db.Uuid
  supplierId  String    @map("supplier_id") @db.Uuid
  status      String    @default("invited") @db.VarChar(20)
  // invited | sent | responded | awarded | declined
  sentAt      DateTime? @map("sent_at")
  respondedAt DateTime? @map("responded_at")
  declinedAt  DateTime? @map("declined_at")
  declineReason String? @map("decline_reason") @db.Text
  // Overall supplier score for this RFQ (calculated on response)
  totalOfferedAmount Decimal? @map("total_offered_amount") @db.Decimal(15, 2)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String    @map("updated_by") @db.Uuid
  tenant        Tenant          @relation(fields: [tenantId],  references: [id])
  rfq           Rfq             @relation(fields: [rfqId],     references: [id], onDelete: Cascade)
  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  responseLines RfqResponseLine[]
  @@unique([rfqId, supplierId])
  @@index([tenantId])
  @@index([rfqId])
  @@index([supplierId])
  @@map("po_rfq_suppliers")
}

model RfqResponseLine {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  rfqSupplierId   String    @map("rfq_supplier_id") @db.Uuid
  rfqLineId       String    @map("rfq_line_id") @db.Uuid
  // What the supplier offered
  offeredQty      Decimal   @map("offered_qty") @db.Decimal(15, 3)
  uom             String    @db.VarChar(20)
  unitPrice       Decimal   @map("unit_price") @db.Decimal(15, 4)
  leadTimeDays    Int       @map("lead_time_days")
  validUntil      DateTime? @map("valid_until") @db.Date
  // Packaging / presentation
  packSize        Decimal?  @map("pack_size") @db.Decimal(15, 4)
  moq             Decimal?  @db.Decimal(15, 3)
  // Award
  isAwarded       Boolean   @default(false) @map("is_awarded")
  awardedQty      Decimal?  @map("awarded_qty") @db.Decimal(15, 3)
  // null = full qty awarded
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")
  createdBy       String    @map("created_by") @db.Uuid
  updatedBy       String    @map("updated_by") @db.Uuid
  tenant      Tenant      @relation(fields: [tenantId],      references: [id])
  rfqSupplier RfqSupplier @relation(fields: [rfqSupplierId], references: [id], onDelete: Cascade)
  rfqLine     RfqLine     @relation(fields: [rfqLineId],     references: [id], onDelete: Cascade)
  @@unique([rfqSupplierId, rfqLineId])
  @@index([tenantId])
  @@index([rfqSupplierId])
  @@index([rfqLineId])
  @@index([isAwarded])
  @@map("po_rfq_response_lines")
}

// ============================================================================
// SPRINT 16 — PRODUCTION PLAN + MRP (mfg_*)
// ProductionPlan → ProductionPlanLine → ProductionOrder (MO)
// CRP hook: crpStatus on ProductionPlan for future capacity analysis
// ============================================================================

model ProductionPlan {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  planNumber  String    @map("plan_number") @db.VarChar(50)  // PP-YYYY-NNNN
  title       String    @db.VarChar(255)
  horizon     String    @db.VarChar(20)
  // weekly | monthly | quarterly
  source      String    @default("free") @db.VarChar(20)
  // free | from_sales_orders
  periodStart DateTime  @map("period_start") @db.Date
  periodEnd   DateTime  @map("period_end")   @db.Date
  status      String    @default("draft") @db.VarChar(20)
  // draft | confirmed | in_progress | completed | cancelled

  // ── CRP hook — Capacity Requirements Planning (Sprint 17+) ───────────────
  // crpStatus: null = not run yet
  // feasible  = all work centers can absorb the load
  // constrained = partial feasibility, some steps need rescheduling
  // infeasible  = cannot be executed with current capacity
  crpStatus   String?   @map("crp_status")  @db.VarChar(20)
  crpRunAt    DateTime? @map("crp_run_at")
  crpNotes    String?   @map("crp_notes")   @db.Text

  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String    @map("created_by") @db.Uuid
  updatedBy   String    @map("updated_by") @db.Uuid
  deletedBy   String?   @map("deleted_by") @db.Uuid

  tenant Tenant               @relation(fields: [tenantId], references: [id])
  lines  ProductionPlanLine[]

  @@unique([tenantId, planNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, horizon])
  @@index([periodStart])
  @@map("mfg_production_plans")
}

model ProductionPlanLine {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  planId      String    @map("plan_id") @db.Uuid
  lineNumber  Int       @map("line_number")
  itemId      String    @map("item_id") @db.Uuid
  bomId       String?   @map("bom_id") @db.Uuid

  // Planned quantities
  plannedQty  Decimal   @map("planned_qty") @db.Decimal(15, 3)
  uom         String    @db.VarChar(20)

  // Schedule
  plannedStart DateTime @map("planned_start") @db.Date
  plannedEnd   DateTime @map("planned_end")   @db.Date

  // Actual vs Planned tracking
  // producedQty updated when linked MOs are completed
  producedQty  Decimal  @default(0) @map("produced_qty") @db.Decimal(15, 3)

  // Source — if plan comes from Sales Orders
  soLineId     String?  @map("so_line_id") @db.Uuid

  // MRP signal — set when MRP generates a GN from this line
  gnLineId     String?  @map("gn_line_id") @db.Uuid

  status       String   @default("pending") @db.VarChar(20)
  // pending | mo_created | in_progress | completed | cancelled

  notes        String?  @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt      @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdBy    String    @map("created_by") @db.Uuid
  updatedBy    String    @map("updated_by") @db.Uuid

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  plan            ProductionPlan  @relation(fields: [planId],   references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId],   references: [id])
  bom             Bom?            @relation(fields: [bomId],    references: [id])
  soLine          SalesOrderLine? @relation(fields: [soLineId], references: [id])
  productionOrders ProductionOrder[]

  @@index([tenantId])
  @@index([planId])
  @@index([itemId])
  @@index([status])
  @@map("mfg_production_plan_lines")
}


