  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  cashFlowProjection CashFlowProjection @relation(fields: [cashFlowProjectionId], references: [id], onDelete: Cascade)
  account            Account?           @relation(fields: [accountId], references: [id])

  @@index([tenantId])
  @@index([cashFlowProjectionId])
  @@index([lineDate])
  @@index([lineType])
  @@index([accountId])
  @@map("ac_cash_flow_lines")
}

// ============================================================================
// ACCOUNTS RECEIVABLE TABLES (ar_*)
// Sprint 5 — AR Invoicing
// ============================================================================

model ArInvoice {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  soId          String?   @map("so_id") @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  invoiceNumber String    @map("invoice_number") @db.VarChar(50)
  invoiceDate   DateTime  @default(dbgenerated("CURRENT_DATE")) @map("invoice_date") @db.Date
  dueDate       DateTime  @map("due_date") @db.Date
  status        String    @default("draft") @db.VarChar(20)
  subtotal      Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount     Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount   Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  paidAmount    Decimal   @default(0) @map("paid_amount") @db.Decimal(15, 2)
  jeId          String?   @map("je_id") @db.Uuid
  currency      String    @default("USD") @db.VarChar(3)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdBy     String    @map("created_by") @db.Uuid
  updatedBy     String    @map("updated_by") @db.Uuid
  deletedBy     String?   @map("deleted_by") @db.Uuid

  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  customer     Customer        @relation(fields: [customerId], references: [id])
  salesOrder   SalesOrder?     @relation(fields: [soId], references: [id])
  journalEntry JournalEntry?   @relation("ArInvoiceJe", fields: [jeId], references: [id])
  lines        ArInvoiceLine[]
  payments     ArPayment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, soId])
  @@index([tenantId, status])
  @@index([invoiceDate])
  @@index([dueDate])
  @@map("ar_invoices")
}

model ArInvoiceLine {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  invoiceId        String    @map("invoice_id") @db.Uuid
  lineNumber       Int       @map("line_number")
  itemId           String?   @map("item_id") @db.Uuid
  description      String?   @db.Text
  quantity         Decimal   @db.Decimal(15, 3)
  uom              String?   @db.VarChar(20)
  unitPrice        Decimal   @map("unit_price") @db.Decimal(15, 4)
  discountPercent  Decimal   @default(0) @map("discount_percent") @db.Decimal(5, 2)
  lineTotal        Decimal   @map("line_total") @db.Decimal(15, 2)
  cogsAmount       Decimal?  @map("cogs_amount") @db.Decimal(15, 2)
  revenueAccountId String?   @map("revenue_account_id") @db.Uuid
  cogsAccountId    String?   @map("cogs_account_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  createdBy        String    @map("created_by") @db.Uuid
  updatedBy        String    @map("updated_by") @db.Uuid
  deletedBy        String?   @map("deleted_by") @db.Uuid

  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  invoice        ArInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item           Item?     @relation(fields: [itemId], references: [id])
  revenueAccount Account?  @relation("ArLineRevenueAccount", fields: [revenueAccountId], references: [id])
  cogsAccount    Account?  @relation("ArLineCogsAccount", fields: [cogsAccountId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@index([itemId])
  @@map("ar_invoice_lines")
}

model ArPayment {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  invoiceId     String    @map("invoice_id") @db.Uuid
  paymentNumber String    @map("payment_number") @db.VarChar(50)
  paymentDate   DateTime  @default(dbgenerated("CURRENT_DATE")) @map("payment_date") @db.Date
  amount        Decimal   @db.Decimal(15, 2)
  paymentMethod String?   @map("payment_method") @db.VarChar(50)
  reference     String?   @db.VarChar(255)
  jeId          String?   @map("je_id") @db.Uuid
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdBy     String    @map("created_by") @db.Uuid
  updatedBy     String    @map("updated_by") @db.Uuid
  deletedBy     String?   @map("deleted_by") @db.Uuid

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  invoice      ArInvoice     @relation(fields: [invoiceId], references: [id])
  journalEntry JournalEntry? @relation("ArPaymentJe", fields: [jeId], references: [id])

  @@unique([tenantId, paymentNumber])
  @@index([tenantId])
  @@index([invoiceId])
  @@index([paymentDate])
  @@map("ar_payments")
}

// ============================================================================
// MANUFACTURING ACTUALS TABLES (mfg_*)
// Sprint 6 — Production Completeness
// ============================================================================

model MoLaborActual {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  moId         String    @map("mo_id") @db.Uuid
  workDate     DateTime? @map("work_date") @db.Date
  employeeId   String?   @map("employee_id") @db.VarChar(100)
  employeeName String?   @map("employee_name") @db.VarChar(255)
  hoursPlanned Decimal?  @map("hours_planned") @db.Decimal(8, 2)
  hoursActual  Decimal   @map("hours_actual") @db.Decimal(8, 2)
  laborRate    Decimal?  @map("labor_rate") @db.Decimal(10, 4)
  laborCost    Decimal?  @map("labor_cost") @db.Decimal(15, 2)
  notes        String?   @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid

  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  productionOrder   ProductionOrder @relation(fields: [moId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([moId])
  @@index([workDate])
  @@map("mfg_mo_labor_actuals")
}

model MoMaterialActual {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  moId         String  @map("mo_id") @db.Uuid
  itemId       String  @map("item_id") @db.Uuid
  qtyPlanned   Decimal @map("qty_planned") @db.Decimal(15, 4)
  qtyActual    Decimal @map("qty_actual") @db.Decimal(15, 4)
  unitCost     Decimal @default(0) @map("unit_cost") @db.Decimal(10, 4)
  varianceCost Decimal @default(0) @map("variance_cost") @db.Decimal(15, 2)
  notes        String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  productionOrder ProductionOrder @relation(fields: [moId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id])

  @@index([tenantId])
  @@index([moId])
  @@index([itemId])
  @@map("mfg_mo_material_actuals")
}

model ProductionVariance {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  moId         String   @map("mo_id") @db.Uuid
  // merma | surplus | labor | material | overhead
  varianceType String   @map("variance_type") @db.VarChar(50)
  description  String?  @db.Text
  quantity     Decimal? @db.Decimal(15, 4)
  unitCost     Decimal? @map("unit_cost") @db.Decimal(10, 4)
  totalCost    Decimal? @map("total_cost") @db.Decimal(15, 2)
  // open | je_posted | closed
  status       String   @default("open") @db.VarChar(20)
  jeId         String?  @map("je_id") @db.Uuid
  notes        String?  @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by") @db.Uuid
  updatedBy String    @map("updated_by") @db.Uuid

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  productionOrder ProductionOrder @relation(fields: [moId], references: [id], onDelete: Cascade)
  journalEntry    JournalEntry?   @relation("VarianceJe", fields: [jeId], references: [id])

  @@index([tenantId])
  @@index([moId])
  @@index([status])
  @@index([varianceType])
  @@map("mfg_production_variances")
}

