// ============================================================================
// in_stock — Sprint 14A: Triple UOM quantities (ADR-014, ADR-019)
// purchaseUom = financial unit of record (ADR-019)
// storageUom  = warehouse operational unit (auxiliary)
// consumptionUom = production operational unit (auxiliary)
// unitCost = WAC per purchaseUom unit
// ============================================================================
model Stock {
  id          String @id @default(uuid()) @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  itemId      String @map("item_id") @db.Uuid
  warehouseId String @map("warehouse_id") @db.Uuid

  // ── Purchase UOM quantities (financial unit of record) ────────────────────
  purchaseQty  Decimal @default(0) @map("purchase_qty") @db.Decimal(15, 3)
  purchaseUom  String  @default("") @map("purchase_uom") @db.VarChar(20)

  // ── Storage UOM quantities (warehouse operational unit) ───────────────────
  // onHandQuantity is kept in sync with storageQty for backward compatibility
  onHandQuantity Decimal @default(0) @map("on_hand_quantity") @db.Decimal(15, 3)
  storageQty     Decimal @default(0) @map("storage_qty")     @db.Decimal(15, 3)
  storageUom     String  @default("") @map("storage_uom")    @db.VarChar(20)

  // ── Consumption UOM quantities (production operational unit) ──────────────
  consumptionQty Decimal @default(0) @map("consumption_qty") @db.Decimal(15, 3)
  consumptionUom String  @default("") @map("consumption_uom") @db.VarChar(20)

  // ── Reserved (in storageUom for warehouse operations) ─────────────────────
  reservedQuantity Decimal @default(0) @map("reserved_quantity") @db.Decimal(15, 3)

  // ── Lot/Serial tracking ───────────────────────────────────────────────────
  lotNumber    String? @map("lot_number")    @db.VarChar(100)
  serialNumber String? @map("serial_number") @db.VarChar(100)

  // ── Costing (ADR-019) ─────────────────────────────────────────────────────
  // unitCost = Weighted Average Cost per purchaseUom unit
  // totalValue = purchaseQty × unitCost (calculated, never stored)
  // unitCostStorage = unitCost / storageFactor (derived at query time)
  // unitCostConsumption = unitCost / consumptionFactor (derived at query time)
  unitCost Decimal? @map("unit_cost") @db.Decimal(15, 4)

  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  levelId String?         @map("level_id") @db.Uuid
  binId   String?         @map("bin_id")   @db.Uuid
  level   WarehouseLevel? @relation(fields: [levelId], references: [id])
  bin     WarehouseBin?   @relation(fields: [binId],   references: [id])

  @@unique([tenantId, itemId, warehouseId, levelId, binId, lotNumber, serialNumber])
  @@index([tenantId])
  @@index([tenantId, itemId])
  @@index([tenantId, warehouseId])
  @@map("in_stock")
}

// ============================================================================
// in_stock_movements — Sprint 14A: Triple UOM + financial audit fields
// quantity/uom = storageQty/storageUom (existing fields, backward compat)
// unitCostAtMovement = WAC snapshot at time of movement (for reversal)
// movementValue = purchaseQty × unitCostAtMovement (pre-calculated audit)
// ============================================================================
model StockMovement {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  movementNumber String   @map("movement_number") @db.VarChar(50)
  movementType   String   @map("movement_type") @db.VarChar(50)
  movementDate   DateTime @default(now()) @map("movement_date")
  itemId         String   @map("item_id") @db.Uuid
  fromWarehouseId String? @map("from_warehouse_id") @db.Uuid
  toWarehouseId   String? @map("to_warehouse_id") @db.Uuid

  // Storage UOM (existing — backward compat, = storageQty/storageUom)
  quantity Decimal @db.Decimal(15, 3)
  uom      String  @db.VarChar(20)

  // Sprint 14A — Purchase UOM (financial unit of record)
  purchaseQty Decimal? @map("purchase_qty") @db.Decimal(15, 3)
  purchaseUom String?  @map("purchase_uom") @db.VarChar(20)

  // Sprint 14A — Consumption UOM (production auxiliary)
  consumptionQty Decimal? @map("consumption_qty") @db.Decimal(15, 3)
  consumptionUom String?  @map("consumption_uom") @db.VarChar(20)

  // Lot/Serial
  lotNumber    String? @map("lot_number")    @db.VarChar(100)
  serialNumber String? @map("serial_number") @db.VarChar(100)

  // Costing
  unitCost Decimal? @map("unit_cost") @db.Decimal(15, 4)

  // Sprint 14A — Financial audit fields (ADR-019)
  // unitCostAtMovement: WAC at time of movement — required for GRN cancellation reversal
  unitCostAtMovement Decimal? @map("unit_cost_at_movement") @db.Decimal(15, 4)
  // movementValue: purchaseQty × unitCostAtMovement — pre-calculated for audit trail
  movementValue      Decimal? @map("movement_value") @db.Decimal(15, 2)

  // Reference
  referenceType String? @map("reference_type") @db.VarChar(50)
  referenceId   String? @map("reference_id") @db.Uuid
  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by") @db.Uuid

  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  item          Item       @relation(fields: [itemId], references: [id])
  fromWarehouse Warehouse? @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse? @relation("MovementToWarehouse",   fields: [toWarehouseId],   references: [id])
  fromLevelId String? @map("from_level_id") @db.Uuid
  toLevelId   String? @map("to_level_id")   @db.Uuid
  fromBinId   String? @map("from_bin_id")   @db.Uuid
  toBinId     String? @map("to_bin_id")     @db.Uuid
  fromLevel WarehouseLevel? @relation("MovementFromLevel", fields: [fromLevelId], references: [id])
  toLevel   WarehouseLevel? @relation("MovementToLevel",   fields: [toLevelId],   references: [id])
  fromBin   WarehouseBin?   @relation("MovementFromBin",   fields: [fromBinId],   references: [id])
  toBin     WarehouseBin?   @relation("MovementToBin",     fields: [toBinId],     references: [id])
  grnLines  GoodsReceiptLine[]

  @@unique([tenantId, movementNumber])
  @@index([tenantId])
  @@index([tenantId, movementNumber])
  @@index([tenantId, itemId])
  @@index([movementDate])
  @@index([movementType])
  @@map("in_stock_movements")
}

