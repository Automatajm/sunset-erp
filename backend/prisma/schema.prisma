  supplierRef   String?   @map("supplier_ref") @db.VarChar(100)
  invoiceDate   DateTime  @default(dbgenerated("CURRENT_DATE")) @map("invoice_date") @db.Date
  dueDate       DateTime  @map("due_date") @db.Date
  status        String    @default("draft") @db.VarChar(20)
  subtotal      Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount     Decimal   @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount   Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
