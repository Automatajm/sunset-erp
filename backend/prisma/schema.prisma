// Sprint 14A: GoodsReceiptLine gains storage + consumption qty fields
// receivedQuantity/uom = purchaseQty/purchaseUom (source of financial truth)
// storageQty/storageUom = warehouse operational quantity (auxiliary)
// consumptionQty/consumptionUom = production operational quantity (auxiliary)
// ============================================================================

model GoodsReceipt {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  grnNumber    String   @map("grn_number") @db.VarChar(50)
